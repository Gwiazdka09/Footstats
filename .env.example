# ============================================================
# FootStats v3.4 — Szablon zmiennych środowiskowych
# Skopiuj do .env i uzupełnij prawdziwymi wartościami.
# NIGDY nie commituj .env do repozytorium!
# ============================================================

# --- BAZA DANYCH ---
# PostgreSQL (Neon.tech lub lokalny):
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- KLUCZE API ---
# football-data.org (obowiązkowy) — https://www.football-data.org/client/register
FOOTBALL_API_KEY=your_football_data_org_key

# api-sports.io (opcjonalny, 1200+ lig) — https://dashboard.api-football.com/register
APISPORTS_KEY=your_apisports_key

# sports.bzzoiro.com (opcjonalny, ML bez limitu) — https://sports.bzzoiro.com/register/
BZZOIRO_KEY=your_bzzoiro_key

# Groq LLM (obowiązkowy dla AI) — https://console.groq.com/
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

# Google API (opcjonalny, RAG embeddings)
GOOGLE_API_KEY=your_google_api_key

# --- BEZPIECZEŃSTWO ---
# Wygeneruj: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_min_32_chars
SECRET_KEY=your_secret_key_min_32_chars

# --- SCRAPER LOGINY ---
STS_LOGIN=your_email@example.com
STS_HASLO=your_sts_password
SUPERBET_LOGIN=your_email@example.com
SUPERBET_PASSWORD=your_superbet_password

# --- TELEGRAM BOT (opcjonalny) ---
# Utwórz bota: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- CORS (URL frontendu) ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- SENTRY (opcjonalny, monitoring błędów) ---
SENTRY_DSN=

# --- UPTIMEROBOT (opcjonalny, status API w GUI) ---
UPTIMEROBOT_API_KEY=

# --- LANGFUSE (opcjonalny, observability LLM) ---
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=

# --- ŚRODOWISKO ---
ENV=development
LOG_LEVEL=INFO
