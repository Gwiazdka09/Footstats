# Jawny .gcloudignore — bez niego `gcloud builds submit` generuje ignore
# z .gitignore, a wzorzec `data/` wycinał też pakiet src/footstats/data
# (incydent 13-20.07: image footstats-jobs bez modułu → ModuleNotFoundError).
.git/
.github/
.gcloudignore
__pycache__/
*.py[cod]
.venv/
venv/
ENV/
.env
.env.*
logs/
# /data/ wykluczone, ale whitelistujemy full_dataset.parquet (Poisson-DC na cloud;
# bez niego cloud-draft robi fallback na bzzoiro-ml). Reszta data/ (SQLite, inne
# parquety, logi) dalej poza build-contextem.
/data/*
!/data/hist_cache/
/data/hist_cache/*
!/data/hist_cache/full_dataset.parquet
tests/
scratch/
*.pdf
.vscode/
.gemini/
.aider*
node_modules/
src/footstats/gui/node_modules/
src/footstats/gui/dist/
